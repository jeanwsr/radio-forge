diff --git a/pyscf/ao2mo/_ao2mo.py b/pyscf/ao2mo/_ao2mo.py
index a2b04b458..a1e209a05 100644
--- a/pyscf/ao2mo/_ao2mo.py
+++ b/pyscf/ao2mo/_ao2mo.py
@@ -15,12 +15,30 @@
 
 import ctypes
 import _ctypes
+import sys
 import numpy
 from pyscf import lib
 from pyscf.gto.moleintor import make_cintopt, make_loc, ascint3
 from pyscf.scf import _vhf
 
 libao2mo = lib.load_library('libao2mo')
+
+if sys.platform == 'win32':
+    libcint = lib.load_library('libcint')
+    class _LibAo2mo:
+        def __init__(self, ao2mo, cint):
+            object.__setattr__(self, '_ao2mo', ao2mo)
+            object.__setattr__(self, '_cint', cint)
+        def __getattr__(self, name):
+            try:
+                return getattr(self._ao2mo, name)
+            except AttributeError:
+                return getattr(self._cint, name)
+        @property
+        def _handle(self):
+            return self._ao2mo._handle
+    libao2mo = _LibAo2mo(libao2mo, libcint)
+
 def _fpointer(name):
     return ctypes.c_void_p(_ctypes.dlsym(libao2mo._handle, name))
 
