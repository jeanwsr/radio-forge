 '''
 
+import sys
 import ctypes
 from functools import lru_cache
 import math
@@ -33,6 +34,19 @@ from pyscf import __config__
 
 _itrf = lib.load_library('libxcfun_itrf')
 
+if sys.platform == 'win32':
+    libxcfun = lib.load_library('libxcfun')
+    class _LibXcfunItrf:
+        def __init__(self, itrf, xcfun):
+            object.__setattr__(self, '_itrf', itrf)
+            object.__setattr__(self, '_xcfun', xcfun)
+        def __getattr__(self, name):
+            try:
+                return getattr(self._itrf, name)
+            except AttributeError:
+                return getattr(self._xcfun, name)
+    _itrf = _LibXcfunItrf(_itrf, libxcfun)
