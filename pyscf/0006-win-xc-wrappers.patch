diff --git a/pyscf/dft/libxc.py b/pyscf/dft/libxc.py
index 5e7db2f38..46d74f377 100644
--- a/pyscf/dft/libxc.py
+++ b/pyscf/dft/libxc.py
@@ -45,6 +45,20 @@ from pyscf.dft import xc_deriv
 from pyscf import __config__
 
 _itrf = lib.load_library('libxc_itrf')
+
+if sys.platform == 'win32':
+    libxc = lib.load_library('xc')
+    class _LibXcItrf:
+        def __init__(self, itrf, xc):
+            object.__setattr__(self, '_itrf', itrf)
+            object.__setattr__(self, '_xc', xc)
+        def __getattr__(self, name):
+            try:
+                return getattr(self._itrf, name)
+            except AttributeError:
+                return getattr(self._xc, name)
+    _itrf = _LibXcItrf(_itrf, libxc)
+
 _itrf.LIBXC_is_lda.restype = ctypes.c_int
 _itrf.LIBXC_is_gga.restype = ctypes.c_int
 _itrf.LIBXC_is_meta_gga.restype = ctypes.c_int
