+import sys
 import ctypes
 import numpy
 from pyscf import lib
 
 libpbc = lib.load_library('libpbc')
+
+if sys.platform == 'win32':
+    libcint = lib.load_library('libcint')
+    class _LibPbc:
+        def __init__(self, pbc, cint):
+            object.__setattr__(self, '_pbc', pbc)
+            object.__setattr__(self, '_cint', cint)
+        def __getattr__(self, name):
+            try:
+                return getattr(self._pbc, name)
+            except AttributeError:
+                return getattr(self._cint, name)
+    libpbc = _LibPbc(libpbc, libcint)
 def _fpointer(name):
     return ctypes.addressof(getattr(libpbc, name))
 
